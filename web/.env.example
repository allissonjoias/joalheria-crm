# Variáveis necessárias pro CRM rodar
# Copie para .env.local (dev) ou configure no EasyPanel (prod)

# === PUBLIC (inlined no bundle JS — visíveis no browser) ===
NEXT_PUBLIC_SUPABASE_URL=https://api.alisson.api.br
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
NEXT_PUBLIC_APP_URL=https://crm.alissonranyel.com.br

# === SERVER-ONLY (lidas em runtime, NUNCA expostas ao browser) ===
# Opcional pra MVP — usamos SECURITY DEFINER no Postgres em vez disso
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# IA (preencher quando ativar IA)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
